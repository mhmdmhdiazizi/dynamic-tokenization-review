@inproceedings{10.1007/978-3-031-18907-4_38,
author = {Shen, Zhengwen and Wang, Jun and Pan, Zaiyu and Wang, Jiangyu and Li, Yulian},
title = {CTFusion: Convolutions Integrate with&nbsp;Transformers for&nbsp;Multi-modal Image Fusion},
year = {2022},
isbn = {978-3-031-18906-7},
publisher = {Springer-Verlag},
address = {Berlin, Heidelberg},
url = {https://doi.org/10.1007/978-3-031-18907-4_38},
doi = {10.1007/978-3-031-18907-4_38},
abstract = {In this paper, we propose a novel pseudo-end-to-end Pre-training multi-model image fusion network, termed CTFusion, to take advantage of convolution operations and vision transformer for multi-modal image fusion. Unlike existing pre-trained models that are based on public datasets, which contain two stages of training with a single input and a fusion strategy designed manually, our method is a simple single-stage pseudo-end-to-end model that uses a dual input adaptive fusion method and can be tested directly. Specifically, the fusion network first adopts a dual dense convolution network to obtain the abundant semantic information, and then the feature map is converted to a token and fed into a multi-path transformer fusion block to model the global-local information of sources images. Finally, we obtain the fusion image by a followed convolutional neural network block. Extensive experiments have been carried out on two publicly available multi-modal datasets, experiment results demonstrate that the proposed model outperforms state-of-the-art methods.},
booktitle = {Pattern Recognition and Computer Vision: 5th Chinese Conference, PRCV 2022, Shenzhen, China, November 4–7, 2022, Proceedings, Part I},
pages = {488–498},
numpages = {11},
keywords = {Multi-modal image, Transformer, Dense convolution network, Multi-path transformer fusion},
location = {Shenzhen, China}
}

