@inproceedings{10.5555/3666122.3669542,
author = {Yang, Chaoqi and Westover, M. Brandon and Sun, Jimeng},
title = {BIOT: biosignal transformer for cross-data learning in the wild},
year = {2023},
publisher = {Curran Associates Inc.},
address = {Red Hook, NY, USA},
abstract = {Biological signals, such as electroencephalograms (EEG), play a crucial role in numerous clinical applications, exhibiting diverse data formats and quality profiles. Current deep learning models for biosignals (based on CNN, RNN, and Transformers) are typically specialized for specific datasets and clinical settings, limiting their broader applicability. This paper explores the development of a flexible biosignal encoder architecture that can enable pre-training on multiple datasets and fine-tuned on downstream biosignal tasks with different formats.To overcome the unique challenges associated with biosignals of various formats, such as mismatched channels, variable sample lengths, and prevalent missing values, we propose Biosignal Transformer (BIOT). The proposed BIOT model can enable cross-data learning with mismatched channels, variable lengths, and missing values by tokenizing different biosignals into unified "sentences" structure. Specifically, we tokenize each channel separately into fixed-length segments containing local signal features and then re-arrange the segments to form a long "sentence". Channel embeddings and relative position embeddings are added to each segment (viewed as "token") to preserve spatio-temporal features.The BIOT model is versatile and applicable to various biosignal learning settings across different datasets, including joint pre-training for larger models. Comprehensive evaluations on EEG, electrocardiogram (ECG), and human activity sensory signals demonstrate that BIOT outperforms robust baselines in common settings and facilitates learning across multiple datasets with different formats. Using CHB-MIT seizure detection task as an example, our vanilla BIOT model shows 3% improvement over baselines in balanced accuracy, and the pre-trained BIOT models (optimized from other data sources) can further bring up to 4% improvements. Our repository is public at https://github.com/ycq091044/BIOT.},
booktitle = {Proceedings of the 37th International Conference on Neural Information Processing Systems},
articleno = {3420},
numpages = {21},
location = {New Orleans, LA, USA},
series = {NIPS '23}
}

@inproceedings{10.1145/3732945.3732960,
author = {Zhang, Gaofeng and Li, Jialei},
title = {The Transformer Oil Temperature Prediction Method Based on the CEEMDAN-PatchTST-Transformer Hybrid Model},
year = {2025},
isbn = {9798400715204},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3732945.3732960},
doi = {10.1145/3732945.3732960},
abstract = {Transformers are a key component of power systems due to increasing electricity demand. Transformers are the nerves of the power system, and the operation of the transformers directly affects the stability of the power supply, the safety and economy of the electrical equipment and their life. High-precision transformer oil temperature prediction helps the transformer to make proactive protective measures, avoid accidents. Many existing methods for oil temperature prediction are unable to extract significant information or learn complex trends from past oil temperature information. In this paper, we propose a hybrid prediction model based on CEEMDAN (Complete Ensemble Empirical Mode Decomposition with Adaptive Noise) and an improved model of PatchTST (Time Series Patch Transformer) to solve this problem. CEEMDAN decomposes the original temperature series into a few of subsequences with different frequencies, providing the opportunity for adaptive analysis of the periodic variation trends in the oil temperature data. Following that, an improved model of PatchTST is used to handle the data, by altering the naive linear prediction head of the initial PatchTST model. The model enhances the correlations among the multiple variable input data for a single-variable prediction task via a Transformer-based prediction head. Finally, the ETTh1 and ETTh2 datasets are used to give a comparison of the prediction results of the proposed CEEMDAN-PatchTST-Transformer model and other models, which verifies that the proposed model has a significant enhancement on the accuracy of prediction, proving the effectiveness of the proposed method in transformer oil temperature forecasting.},
booktitle = {Proceedings of the 2025 4th International Conference on Intelligent Systems, Communications and Computer Networks},
pages = {103–110},
numpages = {8},
keywords = {CEEMDAN, Oil temperature prediction, Transformer},
location = {
},
series = {ISCCN '25}
}

