@inproceedings{10.5555/3737916.3740372,
author = {Yang, Zi and Liu, Ziyue and Choudhary, Samridhi and Xie, Xinfeng and Gao, Cao and Kunzmann, Siegfried and Zhang, Zheng},
title = {CoMERA: computing- and memory-efficient training via rank-adaptive tensor optimization},
year = {2025},
isbn = {9798331314385},
publisher = {Curran Associates Inc.},
address = {Red Hook, NY, USA},
abstract = {Training large AI models such as LLMs and DLRMs costs massive GPUs and computing time. The high training cost has become only affordable to big tech companies, meanwhile also causing increasing concerns about the environmental impact. This paper presents CoMERA, a Computing- and Memory-Efficient training method via Rank-Adaptive tensor optimization. CoMERA achieves rank-adaptive tensor-compressed (pre)-training via a multi-objective optimization formulation and improves the training to provide both a high compression ratio and excellent accuracy in the training process. Our optimized numerical computation (e.g., optimized tensorized embedding and tensor-network contractions) and GPU implementation eliminate part of the run-time overhead in the tensorized training on GPU. This leads to, for the first time, 2 - 3\texttimes{} speedup per training epoch compared with standard training. CoMERA also outperforms the recent GaLore in terms of both memory and computing efficiency. Specifically, CoMERA is 2\texttimes{} faster per training epoch and 9\texttimes{} more memory-efficient than GaLore on a tested six-encoder transformer with single-batch training. Our method also shows ~ 2\texttimes{} speedup than standard pre-training on a BERT-like code-generation LLM while achieving 4.23\texttimes{} compression ratio in pre-training. With further HPC optimization, CoMERA may reduce the pre-training cost of many other LLMs. An implementation of CoMERA is available at https://github.com/ziyangjoy/CoMERA.},
booktitle = {Proceedings of the 38th International Conference on Neural Information Processing Systems},
articleno = {2456},
numpages = {26},
location = {Vancouver, BC, Canada},
series = {NIPS '24}
}

@phdthesis{10.5555/AAI30273737,
author = {Chen, Pengguang},
advisor = {Irwin, King, Kuo Chin},
title = {Improving Compact Deep Neural Network Models in Computer Vision Tasks},
year = {2022},
isbn = {9798357586254},
publisher = {The Chinese University of Hong Kong (Hong Kong)},
abstract = {Deep neural networks (DNNs) have achieved remarkable success in a variety of computer vision tasks. However, the success of DNN is often accompanied by considerable computation and memory consumption, making it a challenging topic to apply to devices with resource budgets. There have been techniques for training fast and compact neural networks, including designing new architectures, network pruning, quantization, and knowledge distillation. We study how to improve compact neural networks. First, designing new architectures is the most direct method, and neural architecture search is proven to be effective in automatically designing neural networks. We propose a simple and efficient framework for extremely fast Neural Architecture Search (NAS). A novel search space with regular building cells is defined, which is different from all previous methods and is friendly to the implementation in mobile devices. Our whole search process only takes 20 hours using one NVIDIA P40 GPU, which is orders of magnitude less than previous NAS approaches. On the ImageNet dataset, the network discovered by our method achieves state-of-the-art top-1 accuracy of 73.34% while maintaining low computational complexity with only 300M FLOPs. Second, knowledge distillation transfers knowledge from the teacher network to the student one, with the goal of greatly improving the performance of the student network. Previous methods mostly focus on proposing feature transformation and loss functions between the same level's features to improve the effectiveness. We differently study the factor of connection path across levels between teacher and student networks, and reveal its great importance. For the first time in knowledge distillation, cross-stage connection paths are proposed. Our new review mechanism is effective and structurally simple. We apply our method to classification, object detection, and instance segmentation tasks. All of them witness significant student network performance improvement. Besides, improving the pretrained weights is another aspect to improve the performance of compact networks. We study unsupervised pretraining in this work. Unsupervised representation learning with contrastive learning achieves great success recently. However, these methods have to duplicate each training batch to construct contrastive pairs, i.e., each training batch and its augmented version should be forwarded simultaneously, leading to nearly double computation resource demand. We propose a novel Jigsaw Clustering pretext task in this thesis, which only needs to forward each training batch itself, nearly reducing the training cost by half. Our method makes use of information from both intra- and inter-images, and outperforms previous single-batch based methods by a large margin. Finally, we study an important neural architecture, vision transformers. We study the vision transformer structure at the mobile level for the dramatic performance drop issue. We show that the vision transformer blocks, which consist of multi-head attention and a feed-forward network, are more suitable to handle high-level information than low-level features. The irregular patch embedding module extracts patches that contain rich high-level information with varying receptive fields. The transformer blocks can obtain useful information from these irregular patches. Then the processed patches pass the adaptive patch merging module to get the final features for the classifier. With our modules, the existing uniform vision transformer structure can now achieve state-of-the-art results in mobile level.},
note = {AAI30273737}
}

@article{10.1109/TIP.2023.3287738,
author = {Zhao, Chunhui and Qin, Boao and Feng, Shou and Zhu, Wenxiang and Sun, Weiwei and Li, Wei and Jia, Xiuping},
title = {Hyperspectral Image Classification With Multi-Attention Transformer and Adaptive Superpixel Segmentation-Based Active Learning},
year = {2023},
issue_date = {2023},
publisher = {IEEE Press},
volume = {32},
issn = {1057-7149},
url = {https://doi.org/10.1109/TIP.2023.3287738},
doi = {10.1109/TIP.2023.3287738},
abstract = {Deep learning (DL) based methods represented by convolutional neural networks (CNNs) are widely used in hyperspectral image classification (HSIC). Some of these methods have strong ability to extract local information, but the extraction of long-range features is slightly inefficient, while others are just the opposite. For example, limited by the receptive fields, CNN is difficult to capture the contextual spectral-spatial features from a long-range spectral-spatial relationship. Besides, the success of DL-based methods is greatly attributed to numerous labeled samples, whose acquisition are time-consuming and cost-consuming. To resolve these problems, a hyperspectral classification framework based on multi-attention Transformer (MAT) and adaptive superpixel segmentation-based active learning (MAT-ASSAL) is proposed, which successfully achieves excellent classification performance, especially under the condition of small-size samples. Firstly, a multi-attention Transformer network is built for HSIC. Specifically, the self-attention module of Transformer is applied to model long-range contextual dependency between spectral-spatial embedding. Moreover, in order to capture local features, an outlook-attention module which can efficiently encode fine-level features and contexts into tokens is utilized to improve the correlation between the center spectral-spatial embedding and its surroundings. Secondly, aiming to train a excellent MAT model through limited labeled samples, a novel active learning (AL) based on superpixel segmentation is proposed to select important samples for MAT. Finally, to better integrate local spatial similarity into active learning, an adaptive superpixel (SP) segmentation algorithm, which can save SPs in uninformative regions and preserve edge details in complex regions, is employed to generate better local spatial constraints for AL. Quantitative and qualitative results indicate that the MAT-ASSAL outperforms seven state-of-the-art methods on three HSI datasets.},
journal = {Trans. Img. Proc.},
month = jan,
pages = {3606–3621},
numpages = {16}
}

@inproceedings{10.1145/3503161.3548024,
author = {Zeng, Pengpeng and Zhu, Jinkuan and Song, Jingkuan and Gao, Lianli},
title = {Progressive Tree-Structured Prototype Network for End-to-End Image Captioning},
year = {2022},
isbn = {9781450392037},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3503161.3548024},
doi = {10.1145/3503161.3548024},
abstract = {Studies of image captioning are shifting towards a trend of a fully end-to-end paradigm by leveraging powerful visual pre-trained models and transformer-based generation architecture for more flexible model training and faster inference speed. State-of-the-art approaches simply extract isolated concepts or attributes to assist description generation. However, such approaches do not consider the hierarchical semantic structure in the textual domain, which leads to an unpredictable mapping between visual representations and concept words. To this end, we propose a novel Progressive Tree-Structured prototype Network (dubbed PTSN), which is the first attempt to narrow down the scope of prediction words with appropriate semantics by modeling the hierarchical textual semantics. Specifically, we design a novel embedding method called tree-structured prototype, producing a set of hierarchical representative embeddings which capture the hierarchical semantic structure in textual space. To utilize such tree-structured prototypes into visual cognition, we also propose a progressive aggregation module to exploit semantic relationships within the image and prototypes. By applying our PTSN to the end-to-end captioning framework, extensive experiments conducted on MSCOCO dataset show that our method achieves a new state-of-the-art performance with 144.2% (single model) and 146.5% (ensemble of 4 models) CIDEr scores on 'Karpathy' split and 141.4% (c5) and 143.9% (c40) CIDEr scores on the official online test server. Trained models and source code have been released at: https://github.com/NovaMind-Z/PTSN.},
booktitle = {Proceedings of the 30th ACM International Conference on Multimedia},
pages = {5210–5218},
numpages = {9},
keywords = {image captioning, swin transformer},
location = {Lisboa, Portugal},
series = {MM '22}
}

@phdthesis{10.5555/AAI28262733,
author = {Li, Yang and Chi, Yuejie and Joe-Wong, Carlee and Kova\v{c}evi\'{c}, Jelena and Wang, Di},
advisor = {F, Moura, Jos\'{e} M.},
title = {Deep Learning Models for Forecasting Graph-Based Time-Dependent Data},
year = {2020},
isbn = {9798569901753},
publisher = {Carnegie Mellon University},
address = {USA},
abstract = {Many real-world applications involve a set of dependent time series, where data in each time series shows dependency across time, and data at different time series may also show dependency. In this dissertation, we refer to the former as temporal dependency and to the latter as spatial dependency. We use a graph to capture the data spatial dependency and refer to this set of dependent time series as graph-based time-dependent data. Graph-based time-dependent data exists in many domains, from economics, to traffic networks, and cloud computing. For example, the gross domestic product (GDP) of various countries at each year of the past century, the taxi ride-hailing demand of different urban locations at each hour of the past decade, and the number of queries to a geo-distributed cloud service running over multiple data centers at each minute of the past month are all graph-based time-dependent data, where the graph represents the relations between the data associated with different countries, different urban locations, or different data centers. Forecasting graph-based time-dependent data helps predict future demand and situations, so that we can proactively allocate resources and take actions to improve the efficiency of target applications. However, this forecasting task is challenging because of (1) the dependencies between the data at different nodes (i.e., spatial dependency), (2) the dependencies between the data at different times (i.e., temporal dependency), and (3) the impact of major exogenous factors on the data. In this dissertation, we propose a new deep learning model GSA-Forecaster for forecasting graph-based time-dependent data. To address the challenge of spatial dependency, GSA-Forecaster starts by learning the structure of the graph that parsimoniously represents the dependency between the data at different nodes (in the case that such graph is not provided as prior knowledge). GSA-Forecaster then leverages sparse linear layers, a new type of sparse neural layers that embed the graph structure into a Transformer architecture. To address effectively the challenge of temporal dependency, we propose GSA-Forecaster that leverages graph sequence attention. To account for the impact of major exogenous factors, GSA-Forecaster treats them as auxiliary information.This thesis presents the following contributions: (1) GSA-Forecaster, a new deep learning model for forecasting graph-based time-dependent data that captures spatial and temporal dependencies of the data and accounts for helpful auxiliary information; (2) extending Transformer to forecasting graph data by identifying the graph structure that represents spatial dependency and embedding this graph structure into Transformer's architecture; (3) graph sequence attention, a new attention mechanism that captures temporal dependency significantly better than prior attention mechanisms; (4) techniques for learning the impact of auxiliary information; (5) application of GSA-Forecaster to forecasting large-scale real-world graph-based time-dependent data (hourly taxi demand in New York City from January 1, 2009 to June 30. 2016), demonstrating its effectiveness over state-of-the-art models DCRNN and Transformer with 10.2% and 12.2% root-mean-square error (RMSE) reduction and 21.3% and 13.5% mean absolute percentage error (MAPE) reduction, respectively.},
note = {AAI28262733}
}

@inproceedings{10.1145/3581783.3612025,
author = {Zhao, Yinjie and Zhao, Lichen and Yu, Qian and Sheng, Lu and Zhang, Jing and Xu, Dong},
title = {Distortion-aware Transformer in 360° Salient Object Detection},
year = {2023},
isbn = {9798400701085},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3581783.3612025},
doi = {10.1145/3581783.3612025},
abstract = {With the emergence of VR and AR, 360° data attracts increasing attention from the computer vision and multimedia communities. Typically, 360° data is projected into 2D ERP (equirectangular projection) images for feature extraction. However, existing methods cannot handle the distortions that result from the projection, hindering the development of 360-data-based tasks. Therefore, in this paper, we propose a Transformer-based model called DATFormer to address the distortion problem. We tackle this issue from two perspectives. Firstly, we introduce two distortion-adaptive modules. The first is a Distortion Mapping Module, which guides the model to pre-adapt to distorted features globally. The second module is a Distortion-Adaptive Attention Block that reduces local distortions on multi-scale features. Secondly, to exploit the unique characteristics of 360° data, we present a learnable relation matrix and use it as part of the positional embedding to further improve performance. Extensive experiments are conducted on three public datasets, and the results show that our model outperforms existing 2D SOD (salient object detection) and 360 SOD methods. The source code is available at https://github.com/yjzhao19981027/DATFormer/.},
booktitle = {Proceedings of the 31st ACM International Conference on Multimedia},
pages = {499–508},
numpages = {10},
keywords = {360 sod, distortion-adaptive, positional embedding, transformer},
location = {Ottawa ON, Canada},
series = {MM '23}
}

