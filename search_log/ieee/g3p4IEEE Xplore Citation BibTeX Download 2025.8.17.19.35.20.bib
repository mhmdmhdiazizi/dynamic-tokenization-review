  journal={IEEE Sensors Journal}, 
  title={An Online Monitoring Device for Twist Angle of Iced Single Conductor of Transmission Line}, 
  year={2025},
  volume={25},
  number={9},
  pages={14850-14859},
  abstract={The real-time and accurate measurement of the twist angle of the overhead conductor during the icing period of the transmission line is of great significance to the monitoring and early warning of the icing state of the power grid. In order to obtain the twist degree of iced conductors in the natural environment, this article proposes an online monitoring device that is used to measure the twist degree of iced single conductor in real time. The device is mainly composed of four parts: data acquisition module, data processing & analysis module, data transmission module, and energy supply module. The data acquisition module takes the MPU-9250 chip as the core, combined with the high dynamic Kalman filter fusion algorithm, can accurately output the current attitude of the module in the form of 3-axis Euler angle. The data processing & analysis function is realized by embedding the data processing methods such as the direction cosine matrix (DCM) method, the noise reduction method based on modulus maxima reconstruction and the singularity detection method into the microcontroller unit (MCU). Meanwhile, the key parameters involved in the data processing process are discussed to guide the application in practical engineering. In terms of data transmission, Long Range Radio (LoRa) and General Packet Radio Service - fourth generation (GPRS-4G) modules are used to realize high and low frequency synchronous acquisition of personal computer (PC) and cloud server, respectively. Energy capture on the conductor is realized by combining double current transformer (CT) and some functional circuits such as protection, rectification, etc. Beside this, field test results show that the device proposed in this article can realize the measurement of twist angle signal with amplitude detection accuracy of 0.25° and cumulative amplitude error of less than 10%.},
  keywords={Conductors;Sensors;Transmission line measurements;Data processing;Ice;Real-time systems;Monitoring;Intelligent sensors;Current measurement;LoRa;Attitude;direction cosine matrix (DCM);iced single conductor;modulus maxima;singularity detection;twist},
  doi={10.1109/JSEN.2025.3552425},
  ISSN={1558-1748},
  month={May},}@ARTICLE{10747043,
  author={Cheng, Jiaming and Li, Ni and Wang, Ban and Bu, Shuhui and Zhou, Ming},
  journal={IEEE Internet of Things Journal}, 
  title={High-Sample-Efficient Multiagent Reinforcement Learning for Navigation and Collision Avoidance of UAV Swarms in Multitask Environments}, 
  year={2024},
  volume={11},
  number={22},
  pages={36420-36437},
  abstract={Multiagent reinforcement learning (MARL) algorithms have shown promise in the Internet of Things devices, such as unmanned aerial vehicle (UAV) swarms. However, the dynamic nature of large-scale swarm systems, with constantly changing numbers of agents and observed neighbors, poses challenges for MARL adaptation. Existing approaches struggle to extract meaningful features and require a substantial number of experience samples, resulting in low-sample efficiency and high-risk ratios. Moreover, these methods are effective in task-specific scenarios and fail to perform well in multitask settings. To overcome these challenges, this study proposes a high-sample efficient and scalable MARL approach for UAV swarms. The proposed approach incorporates a hypernetwork-based embedding attention (HEA) mechanism for the state representation of the policy network and a multiencoder gated transformer with a multilayer attention (MEGTrMA) mechanism for the value function. The HEA automatically generates weights for each agent to adapt to dynamic scenarios, enhancing representation ability and adaptability while reducing the cost of trial and error for improved learning efficiency. The MEGTrMA captures the contribution of each agent to the global observation, establishing long-term dependencies among them and facilitating stable policy learning in multitask scenarios. Simulation results demonstrate that the proposed method is scalable, generalizable, and high-sample efficient. Compared to learning from scratch, our method significantly reduces training time to less than one-fifth of the initial time by progressively increasing the number of UAVs and their corresponding neighbors. Additionally, the average number of collisions is reduced by an order of magnitude for large-scale UAV swarms.},
  keywords={Training;Simulation;Transfer learning;Stochastic processes;Reinforcement learning;Autonomous aerial vehicles;Feature extraction;Transformers;Internet of Things;Vehicle dynamics;Generalization;multiagent reinforcement learning (MARL);multitask;state representation;transformer;unmanned aerial vehicle (UAV) swarms},
  doi={10.1109/JIOT.2024.3409169},
  ISSN={2327-4662},
  month={Nov},}@INPROCEEDINGS{10020632,
  author={Ye, Zian and Hong, Chaoqun and Zeng, Zhiqiang and Zhuang, Weiwei},
  booktitle={2022 IEEE International Conference on Big Data (Big Data)}, 
  title={Self-Supervised Person Re-Identification with Channel-Wise Transformer}, 
  year={2022},
  volume={},
  number={},
  pages={4210-4217},
  abstract={Unsupervised domain adaptive (UDA) person Re-Identification aims to improve the model’s generalization capability from labeled source domain to unlabeled target domain. To this end, a strong and robust method is required to extract discriminative features of pedestrians. Recently, transformer-based method achieves great performance on person Re-Identification (ReID). However, due to the domain gap between ImageNet and ReID datasets, it requires a large pre-training dataset to boost performance on Vision Transformer (ViT). To this end, we first investigate self-supervised learning methods with ViTs pretrained on LUPerson datasets, and find it significantly outperforms ImageNet supervised pre-training models on ReID tasks. A Catastrophic Forgetting Score (CFS) is also used to select a subset of LUPerson, which reduces the training time and improves performance. We then proposed a channel-wise self-attention module to reduce the computing cost on the class token. A dual prototype contrastive learning is proposed to fully exploit the hard feature on memory bank under unsupervised domain adaptation. Finally, we achieve state-of-the-art performance on Market-1501 and MSMT17. Our model achieves 91.5%/69.6% mAP accuracy on Market-1501/MSMT17 for supervised ReID, and 90.7%/57.4% mAP for MS2MA/MA2MS UDA ReID.},
  keywords={Training;Adaptation models;Computational modeling;Prototypes;Self-supervised learning;Big Data;Transformers;person re-identification;domain adaptation;contrastive learning;transformer;self-supervised learning},
