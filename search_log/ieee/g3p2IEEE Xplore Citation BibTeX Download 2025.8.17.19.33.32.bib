  ISSN={1938-1883},
  month={June},}@INPROCEEDINGS{11063892,
  author={Liu, Bingyan and Wu, Li and Li, Jinwen and Wang, Xiaoying},
  booktitle={2025 5th International Conference on Neural Networks, Information and Communication Engineering (NNICE)}, 
  title={A Self-Supervised Pre-Training Method Combining Sequential Reconstruction and Contrastive Learning for Time Series Forecasting}, 
  year={2025},
  volume={},
  number={},
  pages={1927-1935},
  abstract={Accurately predicting future trends and dynamic changes is essential for time series prediction tasks such as weather forecasting and energy management. Although deep learning models demonstrate superior performance, they still face challenges such as prolonged training cycles and a heavy reliance on target data. Self-supervised pre-training techniques leverage unlabeled time series data to learn generalized representations, significantly enhancing the prediction efficiency and transferability of the model. However, traditional masked modeling approaches tend to disrupt the global temporal dependencies, making it challenging to adequately capture the dynamic changing patterns of time series data. To address this, we propose a self-supervised pre-training method that combines sequential reconstruction and contrastive learning, applied to the Cross-Patch Aggregated Transformer (CPAT) model. The resulting pre-trained model, PT-CPAT, is capable of directly predicting time series of different lengths. Sequential reconstruction guides the model to restore the original order by perturbing patch sequences, enabling the model to learn both global and local dependencies of the time series. Contrastive learning improves the model's feature extraction and pattern recognition abilities by generating positive and negative sample pairs. Experimental results show that PT-CPAT outperforms baseline models in zero-shot and few-shot forecasting performance on most time series datasets, demonstrating significant generalization and transfer capabilities.},
  keywords={Training;Time series analysis;Zero shot learning;Weather forecasting;Contrastive learning;Predictive models;Transformers;Data models;Robustness;Forecasting;time series forecasting;transformer;self-supervised pre-training;few-shot learning;zero-shot learning},
