  booktitle={2024 IEEE Smart World Congress (SWC)}, 
  title={Trans-Mamba: The Cross-network of Transformer and Mamba for Traffic Flow Prediction}, 
  year={2024},
  volume={},
  number={},
  pages={219-226},
  abstract={Traffic flow prediction is a crucial aspect of intelligent transportation systems. It holds significant importance in optimizing traffic management and enhancing road safety. However, the task of traffic flow forecasting remains a significant challenge due to its inherent complexity, dynamic nature, and the presence of long-range dependencies. Existing graph neural network methods exhibit two primary limitations. Firstly, when static graphs are employed to capture spatial dependencies, they fail to account for the dynamics in these dependencies. Secondly, these methods struggle to effectively capture long-range spatial dependencies. Furthermore, attention-based methods, while potentially addressing some of these issues, require substantial computational and memory resources, leading to inefficiencies. We design a cross-network model that combines Transformer and Mamba architectures for traffic flow prediction, which efficiently captures dynamic long-range spatio-temporal dependencies. The model architecture is composed of three main components: a learnable spatio-temporal embedding layer that adaptively captures the unique features of different nodes and time; stacked spatio-temporal blocks, which include two temporal blocks and one spatial block arranged between them to effectively capture spatio-temporal dependencies; and a fully connected output layer that generates the final predictions. Experiments on three public real-world datasets demonstrate the effectiveness of TransMamba. Specifically, the model improves the mean absolute error (MAE) and root mean square error (RMSE) by 2.59% and 4.14%, respectively, on the PeMS08 dataset. Additionally, ablation studies confirm the effectiveness and efficiency of each component of the model.},
  keywords={Adaptation models;Computational modeling;Predictive models;Transformers;Road safety;Graph neural networks;Complexity theory;Forecasting;Root mean square;Intelligent transportation systems;Traffic Prediction;Spatio-temporal Model;Transformer;Mamba},
  doi={10.1109/SWC62898.2024.00064},
  ISSN={2993-396X},
  month={Dec},}@ARTICLE{10185089,
  author={Liu, Ajian and Tan, Zichang and Yu, Zitong and Zhao, Chenxu and Wan, Jun and Liang, Yanyan and Lei, Zhen and Zhang, Du and Li, Stan Z. and Guo, Guodong},
  journal={IEEE Transactions on Information Forensics and Security}, 
  title={FM-ViT: Flexible Modal Vision Transformers for Face Anti-Spoofing}, 
